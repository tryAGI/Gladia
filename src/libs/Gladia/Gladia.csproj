<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);MEAI001</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>Generated C# SDK for Gladia — speech-to-text transcription in 100+ languages with pre-recorded and live streaming support.</Description>
    <PackageTags>gladia;speech-to-text;transcription;stt;audio;live;streaming;meai;api;sdk;dotnet;openapi;generated</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.4.1" />
  </ItemGroup>

</Project>
